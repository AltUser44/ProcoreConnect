# Local Postgres connection (used by config/database.yml via dotenv-rails)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=change-me

# Comma-separated list of allowed React origins for CORS.
CORS_ORIGINS=http://localhost:3001

# Sidekiq / Redis (used by config/initializers/sidekiq.rb).
# In Docker (Phase 6) this becomes redis://redis:6379/0.
REDIS_URL=redis://localhost:6379/0

# Optional Sidekiq tuning.
# SIDEKIQ_CONCURRENCY=5

# Production-only: DB password for the dedicated application role.
# PROCORECONNECT_DATABASE_PASSWORD=

# JWT signing key. If unset, falls back to Rails.application.secret_key_base.
# Generate with: bundle exec rails secret
# JWT_SECRET=
