# Copy to `.env` in the repo root and fill in secrets BEFORE running:
#   docker compose up --build
#
# All values below are required for the web/sidekiq services to boot.
# `.env` itself is gitignored.

# --- Postgres ---
POSTGRES_USER=procoreconnect
POSTGRES_PASSWORD=change-me-please
POSTGRES_DB=procoreconnect_production
POSTGRES_PORT=5433       # host-side port; container always listens on 5432

# --- Rails secrets ---
# Generate each value with: bundle exec rails secret
SECRET_KEY_BASE=replace-with-bundle-exec-rails-secret-output
JWT_SECRET=replace-with-bundle-exec-rails-secret-output

# --- Active Record Encryption keys ---
# Generate fresh keys with: bundle exec rails db:encryption:init
AR_ENCRYPTION_PRIMARY_KEY=replace-me
AR_ENCRYPTION_DETERMINISTIC_KEY=replace-me
AR_ENCRYPTION_KEY_DERIVATION_SALT=replace-me

# --- Network ---
WEB_PORT=3000            # Rails on host
FRONTEND_PORT=8080       # nginx (SPA + /api proxy) on host
CORS_ORIGINS=http://localhost:8080
