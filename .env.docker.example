# =============================================================================
# Local production-like stack (copy to repo root as `.env`, then: docker compose up --build)
# =============================================================================
# `.env` is gitignored. Never commit real secrets.
#
# `docker compose` reads this file and passes values into the Rails/Postgres/Redis
# services. In particular, POSTGRES_PASSWORD is wired to both:
#   DATABASE_PASSWORD and PROCORECONNECT_DATABASE_PASSWORD
# (see `docker-compose.yml` web / sidekiq). Keep POSTGRES_* and the generated
# secrets below in sync with what you expect for `procoreconnect_production`.
#
# Generate commands (from `procoreconnect/` with Ruby in PATH):
#   bundle exec rails secret
#   bundle exec rails db:encryption:init
# =============================================================================

# --- Postgres (container) --------------------------------------------------
POSTGRES_USER=procoreconnect
POSTGRES_PASSWORD=change-me-please
POSTGRES_DB=procoreconnect_production
# Host port mapped to container 5432 (avoids clashing with a local Postgres)
POSTGRES_PORT=5433

# --- Rails & Sidekiq (required; production boot will fail if unset) -------
SECRET_KEY_BASE=replace-with-output-of-bundle-exec-rails-secret
JWT_SECRET=replace-with-a-second-unique-rails-secret-output
AR_ENCRYPTION_PRIMARY_KEY=replace-with-output-of-rails-db-encryption-init
AR_ENCRYPTION_DETERMINISTIC_KEY=replace-with-output-of-rails-db-encryption-init
AR_ENCRYPTION_KEY_DERIVATION_SALT=replace-with-output-of-rails-db-encryption-init

# --- Browser CORS (SPA is usually http://localhost:8080 in this layout) ----
CORS_ORIGINS=http://localhost:8080

# --- Published ports (host) ------------------------------------------------
WEB_PORT=3000
FRONTEND_PORT=8080

# Optional: set to "true" only behind TLS / reverse proxy in real deploys
# RAILS_FORCE_SSL=false
