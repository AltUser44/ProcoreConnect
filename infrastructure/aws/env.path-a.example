# Copy to your EC2 deploy directory as the filename `.env` (same folder as docker-compose.path-a.yml).
# chmod 600 .env
# Do not commit `.env` — it contains secrets.
#
# Replace placeholders. DATABASE_HOST is the RDS *endpoint* hostname (from path-a-02 or RDS console).
# Account ID / ECR: change if you use a different registry.

DATABASE_HOST=procoreconnect-db.CHANGEME.us-east-1.rds.amazonaws.com
DATABASE_PORT=5432
DATABASE_USERNAME=procoreconnect
PROCORECONNECT_DATABASE_PASSWORD=CHANGEME

RAILS_LOG_TO_STDOUT=1
RAILS_SERVE_STATIC_FILES=1
RAILS_FORCE_SSL=false

# Generate (after docker login + pull, on EC2):
#   docker run --rm 905838125586.dkr.ecr.us-east-1.amazonaws.com/procoreconnect-web:latest bin/rails secret
# Run it twice; use the two outputs for SECRET_KEY_BASE and JWT_SECRET.
SECRET_KEY_BASE=CHANGEME
JWT_SECRET=CHANGEME

# From a machine with the app bundle (e.g. dev):  bundle exec rails db:encryption:init
# Or in container: docker run --rm -e RAILS_ENV=development .../procoreconnect-web:latest bin/rails db:encryption:init
AR_ENCRYPTION_PRIMARY_KEY=CHANGEME
AR_ENCRYPTION_DETERMINISTIC_KEY=CHANGEME
AR_ENCRYPTION_KEY_DERIVATION_SALT=CHANGEME

# Public URL of the *frontend* (CORS). Path A: http://YOUR_PUBLIC_EIP  (port 80 → no :port)
CORS_ORIGINS=http://YOUR_PUBLIC_EIP

# Must match the compose `redis` service name (default bridge DNS).
REDIS_URL=redis://redis:6379/0
